[gcp."my-gcp-project:us-east5-c"]
project = "my-gcp-project"
region = "us-east5"
zone = "us-east5-c"
cluster = "my-cluster"
network = "projects/my-gcp-project/global/networks/default"
subnetwork = "projects/my-gcp-project/regions/us-east5-c/subnetworks/default"
permanent_bucket = "my-bucket"
private_bucket = "my-bucket"
ttl_bucket = "my-bucket"
labels = "my-unique-label"
service_account_email = "my-service-account@my-project-id.iam.gserviceaccount.com"
docker_repo = "us-east5-docker.pkg.dev/my-gcp-project/my-repo"
default_dockerfile = "Dockerfile.tpu"
enable_gcp_workload_monitoring = true
workload_id = "my-workload-id"
replica_id = "0"
